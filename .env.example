# ============================================================
# CẤU HÌNH BÍ MẬT HỆ THỐNG RUBYALERT
# ============================================================
# Sao chép file này thành .env rồi điền giá trị thật của bạn.
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)
# ============================================================

# Telegram Bot Token — Lấy từ @BotFather trên Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID — Lấy bằng cách gửi tin nhắn tới bot rồi truy cập:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Google Gemini API Key — Lấy tại https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
